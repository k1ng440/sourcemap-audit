  "version": "1.0.0",
  "description": "Security audit tool: detect exposed source maps and reconstruct original JS/TS sources",
  "main": "sourcemap-audit.mjs",
  "type": "module",
  "bin": {
    "sourcemap-audit": "./sourcemap-audit.mjs",
    "sm-reconstruct": "./reconstruct.mjs",
    "sm-download": "./download-sourcemaps.mjs"
  },
  "scripts": {
    "audit": "node sourcemap-audit.mjs",
    "download": "node download-sourcemaps.mjs",
    "reconstruct": "node reconstruct.mjs"
  },
  "keywords": [
    "security",
    "sourcemap",
    "audit",
    "recon",
    "javascript",
    "typescript"
